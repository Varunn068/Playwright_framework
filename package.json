{
  "name": "playwright_bdd",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "npx cucumber-js tests/features/**/*.feature --require tests/step-definitions/**/*.js",
    "test:registration": "npx cucumber-js tests/features/Registration.feature --require tests/step-definitions/**/*.js",
    "test:login": "npx cucumber-js tests/features/Login.feature --require tests/step-definitions/**/*.js",
    "test:cart": "npx cucumber-js tests/features/Cart.feature --require tests/step-definitions/**/*.js",
    "test:checkout": "npx cucumber-js tests/features/Checkout.feature --require tests/step-definitions/**/*.js",
    "test:smoke": "npx cucumber-js tests/features/**/*.feature --require tests/step-definitions/**/*.js --tags \"@smoke\"",
    "report": "node support/multi-html-report.js",
    "test:report": "node scripts/run-test-report.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.3",
    "moment": "^2.30.1",
    "multiple-cucumber-html-reporter": "^3.10.0"
  },
  "dependencies": {
    "@cucumber/cucumber": "^13.0.0",
    "@faker-js/faker": "^10.5.0",
    "allure-cucumberjs": "^3.10.0",
    "dotenv": "^17.4.2"
  }
}
